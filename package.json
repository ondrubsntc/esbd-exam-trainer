{
  "name": "esbd-study-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Single-user local study app for the oral ESBD state exams.",
  "engines": {
    "node": ">=20.6"
  },
  "scripts": {
    "convert": "node scripts/convert-docx.mjs",
    "parse": "node scripts/parse.mjs",
    "generate-study": "node --env-file=.env scripts/generate-study.mjs",
    "dev": "concurrently -k -n web,api -c blue,magenta \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite",
    "dev:api": "node --watch --env-file=.env server/index.js",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "express": "^5.2.1",
    "mammoth": "^1.12.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.16"
  }
}
